msgid "Shuffle: ON"
msgstr "Aleatorio: ON"

msgid "Shuffle: OFF"
msgstr "Aleatorio: OFF"

msgid "Settings Updated"
msgstr "Configuración actualizada"

msgid "Shuffle ON"
msgstr "Aleatorio Activado"

msgid "Shuffle OFF"
msgstr "Aleatorio Desactivado"

msgid "Randomize playback order"
msgstr "Orden de reproducción aleatorio"

msgid "Play in track/alphabetical order"
msgstr "Reproducción en orden de pista/alfabético"

